      <div class="as-preview">
        <svg viewBox="0 0 40 40"><rect x="6" y="26" width="6" height="8" fill="none" stroke="#CCC" stroke-width="1.5"/><rect x="15" y="18" width="6" height="16" fill="none" stroke="#CCC" stroke-width="1.5"/><rect x="24" y="10" width="6" height="24" fill="none" stroke="#CCC" stroke-width="1.5"/><polyline points="9,24 18,16 27,8" fill="none" stroke="#CCC" stroke-width="1"/></svg>
