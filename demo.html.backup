<!-- TOAST -->
<div id="toast"></div>

<script>
/* =============================================
   Brand fallback HTML (used in Hero)
   ============================================= */
const brandFallbackHTML = `<div style="background:#1C3A2A;padding:64px 48px;aspect-ratio:4/3;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center">
  <div style="font-size:24px;color:#E8D5A3;font-weight:700;line-height:1.6">留住这一刻，<br>也留住了他在场。</div>
  <div style="color:#8BAF8B;font-size:20px;margin:16px 0">✦</div>
  <div style="font-family:'DM Mono',monospace;font-size:13px;color:#8BAF8B">MOMERA 此刻</div>
</div>`;

/* =============================================
   Toast
   ============================================= */
function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.opacity = '1';
  clearTimeout(t._timeout);
  t._timeout = setTimeout(() => t.style.opacity = '0', 2000);
}

/* =============================================
   Emotion Card Generation
   ============================================= */
function generateEmotionCard(){
  document.getElementById('ec-placeholder').style.display = 'none';
  const card = document.getElementById('ec-card');
  card.style.display = 'block';
  card.classList.add('show');
  showToast('情绪卡已生成 ✓');
}

/* =============================================
   Emotion Window - Mode switching
   ============================================= */
const videoEl = document.getElementById('player-video');
const danmuLayer = document.getElementById('danmu-layer');
const adBar = document.getElementById('ad-bar');
const videoLabel = document.getElementById('video-label');
const videoFallback = document.getElementById('video-fallback');
let countdownTimer = null;
let danmuTimers = [];
let currentMode = 'climax';

const VIDEO_SRC = {
  traditional: './assets/videos/content_climax_female.mp4',
  climax: './assets/videos/content_climax_female.mp4',
  buffer: './assets/videos/content_buffer_female.mp4'
};

const VIDEO_LABELS = {
  traditional: '⏸ 传统模式 · 强插广告',
  climax: '高光片段 · 不介入 ✓',
  buffer: '缓冲窗口 · 允许介入 ✓'
};

const DANMU_CONFIG = {
  traditional: {
    texts: ['怎么又是广告！','15秒我数着呢','跳过跳过跳过','能不能别插广告','广告结束了吗'],
    duration: [6,7,6.5,7.5,6], tops: ['8%','20%','33%','46%','58%']
  },
  climax: {
    texts: ['太好哭了😭','这一幕绝了！','求不要跳广告','剧情高潮别打断我','OMG!!!'],
    duration: [9,11,8,10,7.5], tops: ['10%','22%','35%','48%','60%']
  },
  buffer: {
    texts: ['歇一下~','好想发条弹幕'],
    duration: [14,16], tops: ['25%','45%']
  }
};

const LENS_DATA = {
  traditional: {
    dot: '#FF4444', headerBg: 'var(--red)',
    title: '⏸ TRADITIONAL · 传统模式',
    rows: [
      {label:'内容状态', value:'剧情高潮中', color:'var(--yellow)'},
      {label:'系统行为', value:'强制插入前贴片', color:'var(--yellow)'},
      {label:'用户反馈', value:'⏩ 跳过率 ↑67%', color:'var(--yellow)'},
      {label:'广告效果', value:'品牌记忆度极低', color:'rgba(255,255,255,0.5)'}
    ]
  },
  climax: {
    dot: '#00FF88', headerBg: '#111',
    title: 'AI LENS · 实时判断',
    rows: [
      {label:'内容状态', value:'高张力阶段', color:'var(--red)'},
      {label:'弹幕密度', value:'高', color:'var(--red)'},
      {label:'用户沉浸', value:'强', color:'var(--red)'},
      {label:'系统判断', value:'不介入', color:'var(--red)'},
      {label:'广告动作', value:'静默', color:'#fff'}
    ]
  },
  buffer: {
    dot: '#00FF88', headerBg: '#111',
    title: 'AI LENS · 实时判断',
    rows: [
      {label:'内容状态', value:'情绪缓冲窗口', color:'var(--blue)'},
      {label:'弹幕语义', value:'可承接', color:'var(--yellow)'},
      {label:'用户沉浸', value:'中等', color:'var(--yellow)'},
      {label:'系统判断', value:'允许轻量节点', color:'var(--blue)'},
      {label:'广告动作', value:'出现情绪引导', color:'#fff'}
    ]
  }
};

function clearDanmu(){
  danmuLayer.innerHTML = '';
  danmuTimers.forEach(clearTimeout);
  danmuTimers = [];
}

function spawnDanmu(config){
  clearDanmu();
  config.texts.forEach((text, i) => {
    const delay = Math.random() * 2000;
    const t = setTimeout(() => {
      const div = document.createElement('div');
      div.textContent = text;
      div.style.top = config.tops[i];
      div.style.animationDuration = config.duration[i] + 's';
      danmuLayer.appendChild(div);
      // Cleanup after animation
      setTimeout(() => { if(div.parentNode) div.remove(); }, config.duration[i] * 1000 + 500);
    }, delay);
    danmuTimers.push(t);
  });
}

function startCountdown(){
  clearInterval(countdownTimer);
  let count = 15;
  document.getElementById('countdown').textContent = count;
  countdownTimer = setInterval(() => {
    count--;
    document.getElementById('countdown').textContent = count;
    if(count <= 0) clearInterval(countdownTimer);
  }, 1000);
}

function updateLens(mode){
  const data = LENS_DATA[mode];
  const header = document.querySelector('#lens-panel .lens-header');
  document.getElementById('lens-dot').style.background = data.dot;
  header.style.background = data.headerBg;
  document.getElementById('lens-title').textContent = data.title;
  document.getElementById('lens-rows').innerHTML = data.rows.map(r =>
    `<div class="lens-row"><span class="lens-label">${r.label}</span><span class="lens-value" style="color:${r.color}">${r.value}</span></div>`
  ).join('');
}

function switchMode(mode){
  currentMode = mode;
  // Update buttons
  document.querySelectorAll('#ew-toggle button').forEach(b => b.classList.remove('active'));
  document.querySelector(`#ew-toggle [data-mode="${mode}"]`).classList.add('active');

  // Update video
  videoEl.src = VIDEO_SRC[mode];
  videoLabel.textContent = VIDEO_LABELS[mode];

  // Ad bar
  if(mode === 'traditional'){
    adBar.style.display = 'flex';
    startCountdown();
  } else {
    adBar.style.display = 'none';
    clearInterval(countdownTimer);
  }

  // Danmu
  spawnDanmu(DANMU_CONFIG[mode]);

  // Lens
  updateLens(mode);
}

// Bind toggle buttons
document.querySelectorAll('#ew-toggle button').forEach(btn => {
  btn.addEventListener('click', () => switchMode(btn.dataset.mode));
});

// Init
switchMode('climax');

// Video fallback
videoEl.addEventListener('error', () => { videoFallback.style.display = 'flex'; });
videoEl.addEventListener('canplay', () => { videoFallback.style.display = 'none'; });

/* =============================================
   Polaroid Flow - setStep
   ============================================= */
const POL_LENS = {
  1: {dot:'#00FF88',bg:'#111',title:'AI LENS · 实时判断',rows:[
    {label:'内容节点',value:'情绪缓冲窗口',color:'var(--blue)'},
    {label:'当前策略',value:'允许轻量互动节点',color:'var(--blue)'},
    {label:'广告状态',value:'等待用户表达',color:'#fff'}
  ]},
  3: {dot:'#00FF88',bg:'#111',title:'AI LENS · 实时判断',rows:[
    {label:'用户表达',value:'想留住',color:'var(--red)'},
    {label:'情绪意图',value:'留存表达型',color:'var(--yellow)'},
    {label:'路由结果',value:'AI 具身陪伴单元',color:'var(--blue)'},
    {label:'品牌承接',value:'MOMERA 此刻',color:'#fff'}
  ]},
  5: {dot:'#00FF88',bg:'#111',title:'AI LENS · 实时判断',rows:[
    {label:'用户表达',value:'想留住',color:'var(--red)'},
    {label:'情绪意图',value:'留存表达型',color:'var(--yellow)'},
    {label:'路由结果',value:'AI 具身陪伴单元',color:'var(--blue)'},
    {label:'品牌承接',value:'MOMERA 此刻',color:'#fff'}
  ]},
  6: {dot:'#FFE100',bg:'#111',title:'AI LENS · 生成监测',rows:[
    {label:'正在匹配',value:'数字人回应姿态',color:'var(--yellow)'},
    {label:'正在生成',value:'陪伴拍立得结果图',color:'var(--yellow)'},
    {label:'资产类型',value:'粉丝IP具身陪伴',color:'#fff'}
  ]},
  7: {dot:'#00FF88',bg:'#111',title:'AI LENS · 结果',rows:[
    {label:'生成完成',value:'陪伴拍立得',color:'#00FF88'},
    {label:'资产归档',value:'AI 数字资产库',color:'var(--blue)'},
    {label:'商业价值',value:'品牌升级为共创结果',color:'var(--yellow)'}
  ]},
  8: {dot:'#00FF88',bg:'#111',title:'AI LENS · 结果',rows:[
    {label:'生成完成',value:'陪伴拍立得',color:'#00FF88'},
    {label:'资产归档',value:'AI 数字资产库',color:'var(--blue)'},
    {label:'商业价值',value:'品牌升级为共创结果',color:'var(--yellow)'}
  ]}
};

function updatePolLens(step){
  const data = POL_LENS[step];
  if(!data) return;
  const lens = document.getElementById('polaroid-lens');
  document.getElementById('pol-lens-dot').style.background = data.dot;
  lens.querySelector('.lens-header').style.background = data.bg;
  lens.querySelector('.lens-title').textContent = data.title;
  document.getElementById('pol-lens-rows').innerHTML = data.rows.map(r =>
    `<div class="lens-row"><span class="lens-label">${r.label}</span><span class="lens-value" style="color:${r.color}">${r.value}</span></div>`
  ).join('');
}

function setStep(n){
  // Update step list
  document.querySelectorAll('#step-list .step-item').forEach(el => {
    const s = parseInt(el.dataset.step);
    el.classList.remove('active','done');
    if(s < n) el.classList.add('done');
    if(s === n) el.classList.add('active');
  });

  // Show corresponding panel
  document.querySelectorAll('#polaroid-main .step-panel').forEach(p => p.classList.remove('show'));
  const panelMap = {1:1,2:1,3:3,4:3,5:5,6:6,7:7,8:8};
  const panel = document.querySelector(`#polaroid-main [data-panel="${panelMap[n] || n}"]`);
  if(panel) panel.classList.add('show');

  // Update AI Lens
  const lensSteps = [1,3,5,6,7,8];
  const closest = lensSteps.reduce((prev, cur) => (cur <= n ? cur : prev), 1);
  updatePolLens(closest);

  // Step 6: animate checklist
  if(n === 6){
    document.getElementById('check1').classList.add('show');
    document.getElementById('check1').querySelector('.sp-check-box').classList.add('done');
    document.getElementById('check2').classList.remove('show');
    document.getElementById('check2').querySelector('.sp-check-box').classList.remove('done');
    document.getElementById('check3').classList.remove('show');
    document.getElementById('check3').querySelector('.sp-check-box').classList.remove('done');
    setTimeout(() => {
      document.getElementById('check2').classList.add('show');
      document.getElementById('check2').querySelector('.sp-check-box').classList.add('done');
    }, 800);
    setTimeout(() => {
      document.getElementById('check3').classList.add('show');
      document.getElementById('check3').querySelector('.sp-check-box').classList.add('done');
    }, 1600);
    setTimeout(() => setStep(7), 2500);
  }
}

// Step list click navigation
document.querySelectorAll('#step-list .step-item').forEach(el => {
  el.addEventListener('click', () => {
    const s = parseInt(el.dataset.step);
    if(s <= currentPolaroidStep + 1 || el.classList.contains('done')) {
      setStep(s);
    }
  });
});
let currentPolaroidStep = 1;
const origSetStep = setStep;
setStep = function(n){
  currentPolaroidStep = n;
  origSetStep(n);
};

// Init polaroid
updatePolLens(1);

/* =============================================
   Nav - Intersection Observer
   ============================================= */
const navLinks = document.querySelectorAll('#nav-links a');
const sections = document.querySelectorAll('section[id]');
const observer = new IntersectionObserver(entries => {
  entries.forEach(entry => {
    if(entry.isIntersecting){
      const id = entry.target.id;
      navLinks.forEach(a => {
        a.classList.toggle('active', a.getAttribute('href') === '#' + id);
      });
    }
  });
}, { rootMargin: '-30% 0px -60% 0px' });
sections.forEach(s => observer.observe(s));

/* =============================================
   Smooth scroll for all anchor links
   ============================================= */
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const target = document.querySelector(a.getAttribute('href'));
    if(target) target.scrollIntoView({behavior:'smooth'});
  });
});

/* =============================================
   Video error fallbacks
   ============================================= */
document.querySelectorAll('video').forEach(v => {
  v.addEventListener('error', () => {
    const fb = v.parentElement.querySelector('.video-fallback');
    if(fb) fb.style.display = 'flex';
  });
});
</script>
</body>
</html>
