        <svg viewBox="0 0 40 40"><rect x="6" y="8" width="28" height="24" rx="2" fill="none" stroke="#CCC" stroke-width="1.5"/><line x1="6" y1="16" x2="34" y2="16" stroke="#CCC" stroke-width="0.8"/><circle cx="20" cy="20" r="4" fill="none" stroke="#CCC" stroke-width="1"/></svg>
        <span class="as-ph-label">UI 预览</span>
      </div>
    </div>
