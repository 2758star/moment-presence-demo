            <span class="pb-time">24:18</span>
            <span class="pb-icon">💬</span>
            <span class="pb-info">字幕 · 720P · 🎵</span>
          </div>
        </div>
      </div>

      <!-- STATE 3+4: Digital human response -->
      <div class="step-panel" data-panel="3">
        <div class="sp-dh-tag">数字人回应</div>
        <div class="sp-dh-quote">这一刻，好像真的值得被留下来。<br>来吧，我陪你拍一张。</div>
        <div class="sp-dh-media" id="dh-media">
          <img src="./assets/images/digital_human_portrait.png" alt="数字人" onerror="this.style.display='none';this.nextElementSibling.style.display='block'">
          <video src="./assets/videos/digital_human_keep_moment.mp4" muted loop playsinline style="display:none;width:100%" onerror="this.style.display='none';this.parentElement.querySelector('.sp-dh-fallback').style.display='flex'"></video>
          <div class="sp-dh-fallback">数字人形象</div>
        </div>
        <div class="sp-dh-btns">
          <button class="btn btn-blue" onclick="setStep(5)">开启相机</button>
          <button class="btn" onclick="setStep(5)">上传照片</button>
        </div>
      </div>

      <!-- STATE 5: Authorization -->
      <div class="step-panel" data-panel="5">
        <div class="sp-auth">
          <img src="./assets/images/brand_momera_logo.png" alt="MOMERA" class="sp-auth-logo" onerror="this.style.display='none';this.nextElementSibling.style.display='block'" style="margin:0 auto 24px;display:block">
          <div style="display:none;font-weight:900;font-size:18px;margin-bottom:24px">MOMERA 此刻</div>
          <div class="sp-auth-title">此刻 AI 陪伴拍立得</div>
          <div class="sp-auth-desc">拍下你现在的场景，我来陪你把它留住。</div>
          <div class="sp-auth-privacy">仅在你授权后调用相机，画面只用于本次拍立得生成。</div>
          <button class="btn btn-blue" onclick="setStep(6)">使用示例场景</button>
        </div>
      </div>

      <!-- STATE 6: Generating -->
      <div class="step-panel" data-panel="6">
        <div class="sp-gen">
          <div class="sp-gen-title">正在为你生成陪伴拍立得……</div>
          <div class="sp-checklist" id="sp-checklist">
            <div class="sp-check-item show" id="check1"><span class="sp-check-box done">✓</span>正在理解你的表达……</div>
            <div class="sp-check-item" id="check2"><span class="sp-check-box">✓</span>正在匹配陪伴姿态……</div>
            <div class="sp-check-item" id="check3"><span class="sp-check-box">✓</span>正在生成陪伴拍立得……</div>
          </div>
        </div>
      </div>

      <!-- STATE 7: Result -->
      <div class="step-panel" data-panel="7">
        <div class="sp-result">
          <div class="sp-polaroid">
            <img src="./assets/images/polaroid_result_fireworks.png" alt="拍立得" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
            <div class="sp-pol-fallback">✨ 陪伴拍立得</div>
            <div class="sp-pol-brand">MOMERA 此刻 × 此刻在场</div>
          </div>
          <div class="sp-info">
            <div class="sp-res-title">你的陪伴拍立得已生成</div>
            <div class="sp-res-desc">这一张拍立得，替你留住刚刚那一刻。</div>
            <div class="sp-tags"><span>#这一刻被留住</span><span>#和TA同框一下</span></div>
            <div class="sp-res-brand">由 MOMERA 此刻 × 此刻在场 联合生成</div>
            <div class="sp-saved">✓ 已保存至你的 AI 数字资产库</div>
            <div class="sp-res-btns">
              <button class="btn" onclick="showToast('已保存 ✓')">保存图片</button>
              <button class="btn btn-blue" onclick="showToast('分享链接已生成')">分享给好友</button>
              <button class="btn" onclick="setStep(8)">继续观看</button>
            </div>
          </div>
        </div>
      </div>

      <!-- STATE 8: Done / archived -->
      <div class="step-panel" data-panel="8">
        <div class="sp-done">
          <div class="sp-done-emoji">📦</div>
          <div class="sp-done-title">已归档至 AI 数字资产库</div>
          <div class="sp-done-desc">每一次互动，都沉淀为可保存、可展示、可分享的内容资产。</div>
          <a href="#asset-library" class="btn btn-yellow">查看资产库</a>
        </div>
      </div>
    </div>

    <!-- Right: AI Lens -->
    <div class="lens-panel" id="polaroid-lens" style="position:sticky;top:72px;">
      <div class="lens-header"><div class="lens-dot" id="pol-lens-dot"></div><span class="lens-title">AI LENS · 实时判断</span></div>
      <div id="pol-lens-rows"></div>
    </div>
  </div>
</div>
</section>

