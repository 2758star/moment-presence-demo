<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>此刻在场 — 腾讯视频 AI 广告体验编排 Demo</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500;700&family=Noto+Sans+SC:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root{
  --blue:#0B38C8; --red:#D92B1E; --yellow:#FFE100;
  --ink:#111111; --paper:#F2F2EF; --mid:#777777;
  --b:3px solid #111; --sh:5px 5px 0 #111; --sh-lg:7px 7px 0 #111;
}
*{margin:0;padding:0;box-sizing:border-box;border-radius:0!important;}
html{scroll-behavior:smooth;}
body{
  background:var(--paper); font-family:'Noto Sans SC',sans-serif;
  color:var(--ink); padding-top:56px;
  background-color:var(--paper);
  background-image:radial-gradient(circle,#C4C4BC 1px,transparent 1px);
  background-size:20px 20px;
}
.inner{max-width:1280px;margin:0 auto;padding:96px 64px;}
.func-tag{font-family:'DM Mono',monospace;font-size:12px;color:var(--blue);letter-spacing:3px;text-transform:uppercase;}
.sec-title{font-size:clamp(40px,5vw,72px);font-weight:900;line-height:1.1;letter-spacing:-2px;}
.sec-desc{font-size:16px;color:var(--mid);margin-top:12px;line-height:1.6;}
.btn{
  display:inline-block;padding:12px 28px;font-size:14px;font-weight:700;
  border:var(--b);box-shadow:var(--sh);cursor:pointer;text-decoration:none;
  font-family:inherit;transition:all 0.1s;background:#fff;color:var(--ink);
}
.btn:hover{transform:translate(5px,5px);box-shadow:none;}
.btn-blue{background:var(--blue);color:#fff;}
.btn-red{background:var(--red);color:#fff;}
.btn-yellow{background:var(--yellow);color:var(--ink);}

/* Nav */
#main-nav{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  height:56px;background:#fff;border-bottom:var(--b);
  display:flex;align-items:center;padding:0 24px;gap:16px;
}
#main-nav .nav-brand{display:flex;align-items:center;gap:10px;flex-shrink:0;}
#main-nav .nav-brand .sq{width:16px;height:16px;background:var(--ink);flex-shrink:0;}
#main-nav .nav-brand .name{font-weight:900;font-size:15px;white-space:nowrap;}
#main-nav .nav-brand .divider{width:1px;height:20px;background:#DDD;margin:0 4px;}
#main-nav .nav-brand .sub{font-family:'DM Mono',monospace;font-size:10px;color:#999;letter-spacing:2px;white-space:nowrap;}
#main-nav .nav-links{display:flex;gap:0;flex:1;justify-content:center;overflow-x:auto;scrollbar-width:none;}
#main-nav .nav-links::-webkit-scrollbar{display:none;}
#main-nav .nav-links a{
  font-size:12px;font-weight:700;color:var(--ink);text-decoration:none;
  padding:6px 12px;white-space:nowrap;transition:all 0.1s;
}
#main-nav .nav-links a:hover{background:#F2F2EF;}
#main-nav .nav-links a.active{background:var(--ink);color:var(--yellow);padding:4px 8px;}
#main-nav .nav-tag{
  flex-shrink:0;border:2px solid var(--red);color:var(--red);
  padding:4px 12px;font-family:'DM Mono',monospace;font-size:10px;
  letter-spacing:1px;text-transform:uppercase;
}
@media(max-width:900px){
  #main-nav .nav-links{display:none;}
  #main-nav{justify-content:space-between;}
}

/* Section */
section .inner{padding:96px 64px;}
@media(max-width:768px){section .inner{padding:64px 24px;}}

/* Hero */
#overview .hero-grid{display:grid;grid-template-columns:55fr 45fr;gap:80px;align-items:start;}
#overview .hero-title{font-size:clamp(64px,8vw,96px);font-weight:900;line-height:0.95;letter-spacing:-3px;margin:16px 0 20px;}
#overview .hero-sub{font-size:clamp(16px,2vw,20px);line-height:1.6;color:var(--ink);}
#overview .hero-sub mark{background:var(--yellow);padding:0 4px;color:inherit;}
#overview .hero-btns{display:flex;gap:16px;flex-wrap:wrap;margin:32px 0 48px;}
#overview .cap-cards{display:flex;flex-direction:column;}
#overview .cap-card{
  border:var(--b);padding:20px 24px;background:#fff;
  display:flex;align-items:center;gap:20px;margin-top:-3px;
}
#overview .cap-card:first-child{margin-top:0;}
#overview .cap-card .cap-num{font-family:'DM Mono',monospace;font-size:40px;color:var(--blue);font-weight:700;transition:color 0.1s;}
#overview .cap-card:hover .cap-num{color:var(--red);}
#overview .cap-card .cap-title{font-weight:900;font-size:15px;}
#overview .cap-card .cap-desc{font-size:13px;color:var(--mid);margin-top:4px;}
#overview .hero-right .brand-img-wrap{border:var(--b);box-shadow:var(--sh-lg);overflow:hidden;}
#overview .hero-right .brand-img-wrap img{width:100%;display:block;object-fit:contain;}
#overview .hero-right .logo-wrap{margin-top:20px;}
#overview .hero-right .logo-wrap img{max-width:220px;display:block;border:var(--b);padding:12px 20px;background:#fff;}

/* Pain Point */
#overview .pain-grid{
  margin-top:64px;display:grid;grid-template-columns:1fr 1fr;
  border:var(--b);box-shadow:var(--sh-lg);overflow:hidden;
}
#overview .pain-left{background:var(--red);padding:48px;}
#overview .pain-left .pain-tag{font-family:'DM Mono',monospace;font-size:11px;background:rgba(0,0,0,0.2);color:#fff;padding:4px 12px;display:inline-block;margin-bottom:24px;}
#overview .pain-left .pain-title{font-size:32px;font-weight:900;color:#fff;margin-bottom:32px;}
#overview .pain-left .pain-list{list-style:none;}
#overview .pain-left .pain-list li{padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.9);font-size:15px;}
#overview .pain-left .pain-list li::before{content:'✕';color:var(--yellow);font-size:20px;font-weight:900;margin-right:12px;}
#overview .pain-right{background:var(--blue);padding:48px;border-left:var(--b);}
#overview .pain-right .pain-tag{font-family:'DM Mono',monospace;font-size:11px;background:rgba(255,255,255,0.15);color:var(--yellow);padding:4px 12px;display:inline-block;margin-bottom:24px;}
#overview .pain-right .pain-title{font-size:32px;font-weight:900;color:var(--yellow);margin-bottom:32px;}
#overview .pain-right .pain-list{list-style:none;}
#overview .pain-right .pain-list li{padding:14px 0;border-bottom:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.9);font-size:15px;}
#overview .pain-right .pain-list li::before{content:'✓';color:var(--yellow);font-size:20px;font-weight:900;margin-right:12px;}
#overview .pain-bar{background:var(--ink);padding:24px 48px;text-align:center;font-size:16px;font-weight:700;color:var(--yellow);}

@media(max-width:768px){
  #overview .hero-grid{grid-template-columns:1fr;gap:40px;}
  #overview .pain-grid{grid-template-columns:1fr;}
}

/* Emotion Window Player */
#emotion-window .toggle-group{display:flex;margin:40px 0 32px;border:var(--b);width:fit-content;box-shadow:var(--sh);}
#emotion-window .toggle-group button{
  padding:12px 24px;font-weight:700;font-size:14px;border:none;cursor:pointer;
  font-family:inherit;transition:all 0.15s;
}
#emotion-window .toggle-group .btn-trad{background:var(--red);color:#fff;border-right:var(--b);}
#emotion-window .toggle-group .btn-climax{background:#fff;color:var(--ink);border-right:var(--b);}
#emotion-window .toggle-group .btn-climax.active{background:var(--ink);color:var(--yellow);}
#emotion-window .toggle-group .btn-buffer{background:#fff;color:var(--ink);}
#emotion-window .toggle-group .btn-buffer.active{background:var(--blue);color:var(--yellow);}
#emotion-window .ew-grid{display:grid;grid-template-columns:60fr 40fr;gap:40px;align-items:start;}
@media(max-width:768px){#emotion-window .ew-grid{grid-template-columns:1fr;}}

/* Video player */
.player-wrap{border:var(--b);box-shadow:var(--sh-lg);overflow:hidden;background:#111;}
.player-top{height:44px;background:#1a1a1a;display:flex;align-items:center;justify-content:space-between;padding:0 16px;}
.player-top .pt-left{display:flex;align-items:center;gap:8px;}
.player-top .pt-dot{width:8px;height:8px;background:var(--red);border-radius:50%!important;}
.player-top .pt-name{font-size:13px;color:#fff;font-weight:700;}
.player-top .pt-sep{color:#555;margin:0 4px;}
.player-top .pt-ep{font-size:12px;color:rgba(255,255,255,0.6);}
.player-top .pt-right{display:flex;gap:12px;align-items:center;}
.player-top .pt-vip{font-family:'DM Mono',monospace;font-size:12px;color:var(--yellow);font-weight:700;border:1px solid rgba(255,225,0,0.4);padding:2px 6px;}
.player-top .pt-dots{color:#666;font-size:18px;letter-spacing:2px;}
#ad-bar{height:40px;background:var(--red);display:none;align-items:center;justify-content:space-between;padding:0 16px;}
#ad-bar .ad-text{color:#fff;font-size:13px;font-weight:600;}
#ad-bar .ad-skip{color:rgba(255,255,255,0.3);font-size:12px;cursor:not-allowed;}
.video-container{position:relative;aspect-ratio:16/9;}
.video-container video{width:100%;height:100%;display:block;object-fit:cover;}
.video-fallback{position:absolute;inset:0;background:#1a1a1a;display:none;flex-direction:column;align-items:center;justify-content:center;}
.video-fallback .fb-icon{font-size:48px;color:#333;}
.video-fallback .fb-text{font-family:'DM Mono',monospace;font-size:12px;color:#444;margin-top:12px;}
.danmu-layer{position:absolute;inset:0;overflow:hidden;pointer-events:none;z-index:5;}
.danmu-layer div{position:absolute;white-space:nowrap;font-size:14px;color:rgba(255,255,255,0.85);text-shadow:0 1px 4px rgba(0,0,0,0.7);padding:2px 8px;animation:fly-left linear forwards;}
@keyframes fly-left{from{transform:translateX(calc(100vw + 100%));}to{transform:translateX(-100%);}}
#video-label{position:absolute;bottom:12px;left:12px;z-index:10;background:rgba(0,0,0,0.7);color:#fff;font-family:'DM Mono',monospace;font-size:11px;padding:4px 12px;border:1px solid rgba(255,255,255,0.2);}
.player-bottom{height:48px;background:#1a1a1a;display:flex;align-items:center;padding:0 16px;gap:10px;}
.player-bottom .pb-icon{color:#fff;font-size:14px;}
.player-bottom .pb-time{font-family:'DM Mono',monospace;font-size:11px;color:#888;}
.player-bottom .pb-bar{flex:1;height:3px;background:#333;position:relative;cursor:pointer;}
.player-bottom .pb-fill{width:30%;height:100%;background:var(--red);}
.player-bottom .pb-fill::after{content:'';position:absolute;right:0;top:-3px;width:9px;height:9px;background:#fff;border-radius:50%!important;}
.player-bottom .pb-info{font-family:'DM Mono',monospace;font-size:11px;color:#666;}

/* AI Lens */
.lens-panel{background:var(--ink);border:var(--b);box-shadow:var(--sh);}
.lens-header{padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;gap:10px;}
.lens-dot{width:10px;height:10px;background:#00FF88;animation:blink 1.5s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.3}}
.lens-title{font-family:'DM Mono',monospace;font-size:13px;color:#fff;font-weight:500;letter-spacing:1px;}
.lens-row{padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.08);display:flex;justify-content:space-between;align-items:center;}
.lens-row:last-child{border-bottom:none;}
.lens-label{font-size:13px;color:rgba(255,255,255,0.45);}
.lens-value{font-size:14px;font-weight:700;text-align:right;}

/* Emotion Card */
#emotion-card .ec-grid{display:grid;grid-template-columns:40fr 60fr;gap:64px;align-items:start;}
#emotion-card .ec-left .ec-note{margin-top:32px;font-size:14px;line-height:2;color:var(--mid);border-left:4px solid var(--blue);padding-left:16px;}
#emotion-card .ec-area{border:3px dashed #CCC;padding:48px;text-align:center;color:#CCC;font-family:'DM Mono',monospace;font-size:13px;min-height:200px;display:flex;align-items:center;justify-content:center;transition:all 0.4s;}
#emotion-card .ec-card{display:none;position:relative;border:var(--b);box-shadow:var(--sh-lg);background:#fff;}
#emotion-card .ec-card.show{display:block;animation:fadeIn 0.4s ease-out;}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}
.ec-stamp{position:absolute;top:-14px;right:20px;background:var(--ink);color:var(--yellow);font-family:'DM Mono',monospace;font-size:11px;padding:4px 14px;letter-spacing:2px;z-index:1;}
.ec-yellow-bar{background:var(--yellow);padding:16px 24px;border-bottom:var(--b);font-weight:900;font-size:16px;}
.ec-body{padding:24px;}
.ec-data-row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid #EEE;font-size:14px;}
.ec-data-row .ec-dl{color:var(--mid);}
.ec-data-row .ec-dv{font-weight:700;}
.ec-ai-box{background:var(--paper);border:2px solid var(--ink);padding:16px 20px;margin:16px 0;}
.ec-ai-box .ec-ai-label{font-family:'DM Mono',monospace;font-size:10px;color:var(--mid);}
.ec-ai-box .ec-ai-quote{font-size:16px;font-weight:700;color:var(--ink);line-height:1.8;margin-top:6px;}
.ec-brand{font-size:12px;color:#999;font-family:'DM Mono',monospace;text-align:right;margin-bottom:20px;}
.ec-btns{display:flex;flex-wrap:wrap;gap:8px;}
.ec-btns .btn{font-size:13px;padding:10px 20px;}
@media(max-width:768px){#emotion-card .ec-grid{grid-template-columns:1fr;gap:32px;}}

/* Route Matrix */
.route-cards{display:grid;grid-template-columns:repeat(3,1fr);border:var(--b);box-shadow:var(--sh-lg);margin-top:40px;}
.route-card{padding:32px 28px;border-right:var(--b);}
.route-card:last-child{border-right:none;}
.route-card .rt-tag{font-family:'DM Mono',monospace;font-size:10px;padding:6px 12px;display:inline-block;margin-bottom:16px;color:#fff;}
.route-card:nth-child(1) .rt-tag{background:var(--red);}
.route-card:nth-child(2) .rt-tag{background:var(--ink);}
.route-card:nth-child(3) .rt-tag{background:var(--blue);}
.route-card:nth-child(2){background:var(--paper);}
.route-card:nth-child(3){background:#fff;}
.route-card .rt-user{font-size:22px;font-weight:900;color:var(--ink);}
.route-card .rt-scene{font-size:13px;color:var(--mid);margin:6px 0 20px;}
.route-card .rt-list{list-style:none;}
.route-card .rt-list li{padding:10px 0;border-bottom:1px solid #EEE;font-size:14px;display:flex;align-items:center;gap:10px;}
.route-card .rt-list li::before{content:'';width:3px;height:16px;background:var(--blue);flex-shrink:0;}
.route-bar{margin-top:32px;border:var(--b);background:var(--ink);padding:20px 32px;text-align:center;color:var(--yellow);font-size:15px;font-weight:700;}
@media(max-width:768px){.route-cards{grid-template-columns:1fr;}.route-card{border-right:none;border-bottom:var(--b);}}

/* Scene Rebuild */
.scene-note{border-left:4px solid var(--blue);padding-left:16px;margin:24px 0 40px;font-size:15px;line-height:2;}
.scene-trip{border:var(--b);box-shadow:var(--sh-lg);overflow:hidden;margin-bottom:32px;}
.scene-trip img{width:100%;display:block;object-fit:contain;background:var(--paper);}
.scene-trip .trip-fallback{display:none;background:#E8E8E5;aspect-ratio:21/9;align-items:center;justify-content:center;gap:40px;}
.scene-flow{display:flex;border:var(--b);box-shadow:var(--sh);overflow:hidden;}
.scene-step{flex:1;padding:16px 24px;text-align:center;border-right:var(--b);font-weight:900;font-size:14px;}
.scene-step:last-child{border-right:none;}
.scene-step:nth-child(1){background:#fff;}
.scene-step:nth-child(2){background:var(--paper);}
.scene-step:nth-child(3){background:var(--blue);color:#fff;}
.scene-video-preview{margin-top:48px;}
.scene-video-preview .svp-title{font-size:20px;font-weight:900;margin-bottom:24px;}
.scene-video-preview .svp-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border:var(--b);box-shadow:var(--sh);}
.scene-video-preview .svp-left{padding:20px;border-right:var(--b);}
.scene-video-preview .svp-right{padding:20px;}
.svp-tag{font-family:'DM Mono',monospace;font-size:11px;padding:3px 10px;margin-bottom:12px;display:inline-block;color:#fff;}
.svp-tag.original{background:var(--ink);}
.svp-tag.rebuilt{background:var(--blue);color:var(--yellow);}
.svp-video-wrap{aspect-ratio:16/9;overflow:hidden;background:var(--ink);border:2px solid var(--ink);}
.svp-video-wrap video{width:100%;height:100%;object-fit:cover;}
.svp-scenes{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.svp-scenes .svp-sc{aspect-ratio:9/16;overflow:hidden;}
.svp-scenes video{width:100%;height:100%;object-fit:cover;}
.svp-scenes .svp-sc-label{font-family:'DM Mono',monospace;font-size:10px;margin-top:4px;text-align:center;color:var(--mid);}
@media(max-width:768px){.scene-video-preview .svp-grid{grid-template-columns:1fr;}}

/* Asset Library */
.asset-wall{display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:auto auto;border:var(--b);box-shadow:var(--sh-lg);margin-top:48px;}
.asset-card{border-right:var(--b);border-bottom:var(--b);padding:24px;background:#fff;display:flex;flex-direction:column;}
.asset-card:nth-child(3n){border-right:none;}
.asset-card:nth-child(4),.asset-card:nth-child(5),.asset-card:nth-child(6){border-bottom:none;}
.asset-card:nth-child(2){grid-row:1/3;border:3px solid var(--yellow)!important;box-shadow:none;}
.asset-card .as-type{font-family:'DM Mono',monospace;font-size:10px;color:var(--mid);letter-spacing:1px;}
.asset-card .as-title{font-size:20px;font-weight:900;margin:8px 0;}
.asset-card .as-status{display:inline-block;padding:3px 10px;font-family:'DM Mono',monospace;font-size:11px;font-weight:700;}
.as-status.gen{background:var(--ink);color:var(--yellow);}
.as-status.rare{background:var(--yellow);color:var(--ink);}
.as-status.locked{background:#E8E8E5;color:#999;}
.as-status.lit{background:var(--blue);color:#fff;}
.as-status.ext{background:var(--red);color:#fff;}
.as-status.qtr{background:var(--ink);color:#fff;}
.asset-card .as-tag{font-size:13px;color:var(--blue);margin:6px 0 12px;}
.asset-card .as-preview{aspect-ratio:4/3;background:#F0F0EC;border:1.5px dashed #CCC;margin:8px 0;display:flex;align-items:center;justify-content:center;flex-direction:column;}
.asset-card:nth-child(2) .as-preview{aspect-ratio:3/4;border:2px solid #EEE;background:#F5F0E8;}
.asset-card:nth-child(2) .as-preview img{width:100%;height:100%;object-fit:cover;display:block;}
.as-preview svg{width:40px;height:40px;}
.as-preview .as-ph-label{font-family:'DM Mono',monospace;font-size:11px;color:#CCC;margin-top:8px;}
.asset-bottom{margin-top:32px;font-size:15px;color:var(--mid);text-align:center;padding:24px;border:var(--b);background:#fff;}
@media(max-width:768px){.asset-wall{grid-template-columns:1fr;}.asset-card:nth-child(2){grid-row:auto;}}

/* Polaroid */
#polaroid .pol-grid{display:grid;grid-template-columns:200px 1fr 260px;gap:32px;align-items:start;margin-top:40px;}
@media(max-width:900px){#polaroid .pol-grid{grid-template-columns:1fr;}}
.step-list{display:flex;flex-direction:column;}
.step-item{border:var(--b);border-bottom:none;padding:14px 16px;display:flex;align-items:center;gap:12px;cursor:pointer;background:#fff;transition:all 0.1s;font-size:13px;font-weight:600;}
.step-item:last-child{border-bottom:var(--b);}
.step-item .si-num{font-family:'DM Mono',monospace;font-size:12px;color:var(--mid);width:24px;flex-shrink:0;}
.step-item.active{background:var(--yellow);box-shadow:4px 4px 0 #111;position:relative;z-index:1;}
.step-item.done{background:var(--paper);}
.step-item.done .si-num{color:var(--blue);}
.step-panel{display:none;}
.step-panel.show{display:block;animation:fadeIn 0.3s ease-out;}
/* State 1 - player */
.sp-player{position:relative;}
.sp-player .sp-overlay{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.85);padding:16px 20px;z-index:6;}
.sp-overlay .sp-q{font-size:15px;font-weight:700;color:#fff;margin-bottom:6px;}
.sp-overlay .sp-hint{font-size:13px;color:rgba(255,255,255,0.6);margin-bottom:14px;}
.sp-overlay .sp-quick{display:flex;gap:8px;flex-wrap:wrap;}
.sp-quick button{padding:8px 20px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;}
.sp-quick .sp-want{background:var(--yellow);color:var(--ink);border:2px solid var(--ink);}
.sp-quick .sp-disabled{border:2px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.4);background:transparent;cursor:not-allowed;}
/* State 3 - digital human */
.sp-dh-tag{font-family:'DM Mono',monospace;font-size:11px;color:var(--blue);margin-bottom:12px;}
.sp-dh-quote{font-size:20px;font-weight:900;line-height:1.6;margin-bottom:24px;}
.sp-dh-media{border:var(--b);box-shadow:var(--sh);overflow:hidden;}
.sp-dh-media img{width:100%;max-height:400px;object-fit:contain;display:block;background:#F5F5F5;}
.sp-dh-media video{width:100%;display:block;}
.sp-dh-fallback{background:#E8E8E5;aspect-ratio:4/3;display:none;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:13px;color:#999;}
.sp-dh-btns{display:flex;gap:12px;margin-top:24px;}
/* State 5 - authorize */
.sp-auth{border:var(--b);box-shadow:var(--sh);padding:40px;text-align:center;}
.sp-auth .sp-auth-logo{max-width:160px;margin:0 auto 24px;display:block;}
.sp-auth .sp-auth-title{font-size:22px;font-weight:900;margin-bottom:16px;}
.sp-auth .sp-auth-desc{font-size:15px;color:var(--mid);line-height:2;margin-bottom:24px;}
.sp-auth .sp-auth-privacy{font-size:12px;color:#999;font-family:'DM Mono',monospace;border:1.5px dashed #CCC;padding:12px 16px;margin-bottom:32px;}
.sp-auth .btn{width:100%;text-align:center;}
/* State 6 - generating */
.sp-gen{border:var(--b);box-shadow:var(--sh);padding:40px;}
.sp-gen .sp-gen-title{font-size:18px;font-weight:900;margin-bottom:32px;}
.sp-gen .sp-checklist{display:flex;flex-direction:column;gap:16px;}
.sp-gen .sp-check-item{display:flex;align-items:center;gap:16px;font-size:15px;font-weight:600;opacity:0.3;transition:all 0.4s;}
.sp-gen .sp-check-item.show{opacity:1;}
.sp-gen .sp-check-item .sp-check-box{width:28px;height:28px;border:2px solid var(--ink);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'DM Mono',monospace;font-size:12px;}
.sp-gen .sp-check-item .sp-check-box.done{background:var(--blue);color:var(--yellow);}
/* State 7 - result */
.sp-result{display:grid;grid-template-columns:1fr 1fr;gap:32px;align-items:start;}
.sp-result .sp-polaroid{border:var(--b);box-shadow:var(--sh-lg);background:#fff;padding:16px 16px 48px;}
.sp-result .sp-polaroid img{width:100%;aspect-ratio:1/1;object-fit:cover;display:block;border:1px solid #EEE;}
.sp-result .sp-pol-fallback{aspect-ratio:1/1;background:linear-gradient(135deg,#FFB7C5,#FFDAB9);display:none;align-items:center;justify-content:center;font-size:32px;}
.sp-result .sp-pol-brand{margin-top:12px;text-align:center;font-family:'DM Mono',monospace;font-size:10px;color:#999;}
.sp-result .sp-info{display:flex;flex-direction:column;gap:16px;}
.sp-result .sp-info .sp-res-title{font-size:22px;font-weight:900;}
.sp-result .sp-info .sp-res-desc{font-size:14px;color:var(--mid);line-height:1.8;}
.sp-result .sp-tags{display:flex;gap:8px;flex-wrap:wrap;}
.sp-result .sp-tags span{border:2px solid var(--blue);color:var(--blue);padding:4px 12px;font-family:'DM Mono',monospace;font-size:12px;}
.sp-result .sp-res-brand{font-size:12px;font-family:'DM Mono',monospace;color:#999;}
.sp-result .sp-saved{background:var(--paper);border:var(--b);padding:12px 16px;font-size:13px;font-weight:700;color:var(--blue);}
.sp-result .sp-res-btns{display:flex;flex-wrap:wrap;gap:8px;}
@media(max-width:768px){.sp-result{grid-template-columns:1fr;}}
/* State 8 */
.sp-done{border:var(--b);box-shadow:var(--sh);padding:40px;text-align:center;background:var(--ink);}
.sp-done .sp-done-emoji{font-size:64px;margin-bottom:16px;}
.sp-done .sp-done-title{font-size:22px;font-weight:900;color:#fff;margin-bottom:12px;}
.sp-done .sp-done-desc{font-size:14px;color:rgba(255,255,255,0.6);line-height:1.8;margin-bottom:32px;}

/* Business Value */
#business-value .bv-grid{display:grid;grid-template-columns:repeat(3,1fr);border:var(--b);box-shadow:var(--sh-lg);margin-top:40px;}
#business-value .bv-card{padding:40px 32px;border-right:var(--b);}
#business-value .bv-card:last-child{border-right:none;}
#business-value .bv-card:nth-child(1){background:#fff;}
#business-value .bv-card:nth-child(2){background:var(--paper);}
#business-value .bv-card:nth-child(3){background:var(--blue);}
#business-value .bv-card .bv-emoji{font-size:32px;margin-bottom:16px;}
#business-value .bv-card .bv-title{font-size:24px;font-weight:900;margin-bottom:20px;padding-bottom:16px;border-bottom:var(--b);}
#business-value .bv-card:nth-child(3) .bv-title{color:var(--yellow);}
#business-value .bv-card .bv-list{list-style:none;}
#business-value .bv-card .bv-list li{padding:8px 0;font-size:15px;display:flex;align-items:center;gap:10px;}
#business-value .bv-card:nth-child(3) .bv-list li{color:rgba(255,255,255,0.9);}
#business-value .bv-card .bv-list li::before{content:'→';color:var(--blue);font-weight:700;}
#business-value .bv-card:nth-child(3) .bv-list li::before{color:var(--yellow);}
.bv-conclusion{margin-top:40px;border:var(--b);box-shadow:var(--sh-lg);background:#fff;padding:40px;text-align:center;font-size:clamp(18px,2.5vw,26px);font-weight:900;line-height:1.8;}
.bv-conclusion mark{background:var(--yellow);padding:0 6px;color:inherit;}
@media(max-width:768px){#business-value .bv-grid{grid-template-columns:1fr;}}

/* Footer */
.site-footer{border-top:var(--b);background:var(--ink);padding:32px 64px;display:flex;justify-content:space-between;align-items:center;}
.site-footer .ft-left{display:flex;flex-direction:column;gap:4px;}
.site-footer .ft-left .ft-main{font-family:'DM Mono',monospace;font-size:12px;color:rgba(255,255,255,0.5);}
.site-footer .ft-left .ft-sub{font-family:'DM Mono',monospace;font-size:11px;color:rgba(255,255,255,0.3);}
@media(max-width:768px){.site-footer{padding:24px;flex-direction:column;gap:16px;}}

/* Toast */
#toast{position:fixed;bottom:32px;right:32px;z-index:9999;background:var(--ink);color:var(--yellow);padding:12px 24px;border:var(--b);box-shadow:var(--sh);font-family:'DM Mono',monospace;font-size:13px;opacity:0;transition:opacity 0.2s;pointer-events:none;}
</style>
</head>
<body>

<!-- NAV -->
<nav id="main-nav">
  <div class="nav-brand">
    <div class="sq"></div>
    <span class="name">此刻在场</span>
    <div class="divider"></div>
    <span class="sub">MOMENT PRESENCE</span>
  </div>
  <div class="nav-links" id="nav-links">
    <a href="#overview">OVERVIEW</a>
    <a href="#emotion-window">01 情绪判断</a>
    <a href="#emotion-card">02 情绪卡</a>
    <a href="#route-matrix">03 路由矩阵</a>
    <a href="#scene-rebuild">04 场景改造</a>
    <a href="#asset-library">05 资产库</a>
    <a href="#polaroid">06 拍立得</a>
    <a href="#business-value">07 商业价值</a>
  </div>
  <div class="nav-tag">DEMO · 腾讯视频 AI</div>
</nav>

<!-- SECTION 00: HERO + PAIN POINT -->
<section id="overview">
<div class="inner">
  <div class="hero-grid">
    <div>
      <p class="func-tag">腾讯视频 · AI 广告体验编排 DEMO</p>
      <h1 class="hero-title">此刻在场</h1>
      <p class="hero-sub">让广告从「<mark>卖曝光</mark>」，升级为「<mark>卖场景、卖参与、卖表达</mark>」。</p>
      <div class="hero-btns">
        <a href="#emotion-window" class="btn btn-blue">开始体验 DEMO</a>
        <a href="#route-matrix" class="btn">查看能力矩阵</a>
      </div>
      <div class="cap-cards">
        <div class="cap-card"><span class="cap-num">01</span><div><div class="cap-title">AI 情绪判断</div><div class="cap-desc">判断此刻该不该介入</div></div></div>
        <div class="cap-card"><span class="cap-num">02</span><div><div class="cap-title">广告版本路由</div><div class="cap-desc">决定该进入哪种广告体验</div></div></div>
        <div class="cap-card"><span class="cap-num">03</span><div><div class="cap-title">结果资产生成</div><div class="cap-desc">让广告变成可保存可分享的用户资产</div></div></div>
      </div>
    </div>
    <div class="hero-right">
      <div class="brand-img-wrap" id="brand-img-wrap">
        <img src="./assets/images/brand_momera_slogan_card.png" alt="MOMERA" onerror="this.parentElement.innerHTML=brandFallbackHTML">
      </div>
      <div class="logo-wrap">
        <img src="./assets/images/brand_momera_logo.png" alt="MOMERA" onerror="this.outerHTML='<div style=\'font-weight:900;font-size:14px;border:3px solid #111;padding:12px 20px;background:#fff;display:inline-block\'>MOMERA 此刻 · AI 陪伴拍立得</div>'">
      </div>
    </div>
  </div>

  <!-- Pain point contrast -->
  <div class="pain-grid">
    <div class="pain-left">
      <div class="pain-tag">✕ BEFORE · 传统广告模式</div>
      <div class="pain-title">强插广告，毫无感知</div>
      <ul class="pain-list">
        <li>不分场合，剧情高潮直接打断</li>
        <li>用户跳过率 67%，品牌无效曝光</li>
        <li>广告消失即消失，零资产沉淀</li>
      </ul>
    </div>
    <div class="pain-right">
      <div class="pain-tag">✓ AFTER · 此刻在场</div>
      <div class="pain-title">感知时机，随场景共鸣</div>
      <ul class="pain-list">
        <li>AI 判断情绪窗口，高潮期静默不介入</li>
        <li>缓冲期轻量节点，用户主动表达意愿</li>
        <li>互动结果沉淀为可保存的数字资产</li>
      </ul>
    </div>
  </div>
  <div class="pain-bar">广告的关键不只是曝光，而是选择什么时候、以什么方式在场。</div>
</div>
</section>

<!-- SECTION 01: EMOTION WINDOW -->
<section id="emotion-window">
<div class="inner">
  <p class="func-tag">FUNC 01</p>
  <h2 class="sec-title">情绪窗口判断</h2>
  <p class="sec-desc">AI 的价值不只是更会投广告，也包括知道什么时候不投广告。</p>

  <div class="toggle-group" id="ew-toggle">
    <button class="btn-trad" data-mode="traditional">传统广告（对比）</button>
    <button class="btn-climax active" data-mode="climax">高光片段 · 不介入</button>
    <button class="btn-buffer" data-mode="buffer">缓冲片段 · 可介入</button>
  </div>

  <div class="ew-grid">
    <div class="player-wrap">
      <div class="player-top">
        <div class="pt-left">
          <div class="pt-dot"></div>
          <span class="pt-name">腾讯视频</span>
          <span class="pt-sep">·</span>
          <span class="pt-ep">假装偶然 · 第12集</span>
        </div>
        <div class="pt-right">
          <span class="pt-vip">VIP</span>
          <span class="pt-dots">···</span>
        </div>
      </div>
      <div id="ad-bar"><span class="ad-text">⏸ 广告时间：您的视频将在 <span id="countdown">15</span> 秒后恢复播放</span><span class="ad-skip">跳过广告（VIP 专属）</span></div>
      <div class="video-container">
        <video id="player-video" src="./assets/videos/content_climax_female.mp4" muted loop playsinline autoplay></video>
        <div class="video-fallback" id="video-fallback"><span class="fb-icon">▶</span><span class="fb-text">视频素材加载中</span></div>
        <div class="danmu-layer" id="danmu-layer"></div>
        <div id="video-label">高光片段 · 不介入 ✓</div>
      </div>
      <div class="player-bottom">
        <span class="pb-icon">▶</span>
        <span class="pb-time">00:43</span>
        <div class="pb-bar"><div class="pb-fill"></div></div>
        <span class="pb-time">24:18</span>
        <span class="pb-icon">💬</span>
        <span class="pb-info">字幕 · 720P · 🎵</span>
        <span class="pb-info" style="margin-left:auto">跳过片头 ▶</span>
      </div>
    </div>

    <div class="lens-panel" id="lens-panel">
      <div class="lens-header"><div class="lens-dot" id="lens-dot"></div><span class="lens-title" id="lens-title">AI LENS · 实时判断</span></div>
      <div id="lens-rows"></div>
    </div>
  </div>
</div>
</section>

<!-- SECTION 02: EMOTION CARD -->
<section id="emotion-card">
<div class="inner">
  <div class="ec-grid">
    <div class="ec-left">
      <p class="func-tag">FUNC 04</p>
      <h2 class="sec-title">情绪卡生成 DEMO</h2>
      <p class="sec-desc">演示轻量结果资产：本集情绪卡。</p>
      <button class="btn btn-blue" style="margin-top:40px" onclick="generateEmotionCard()">生成本集情绪卡</button>
      <p class="ec-note">AI 的价值不只是更会投广告，也包括知道什么时候不投广告。</p>
    </div>
    <div>
      <div class="ec-area" id="ec-placeholder">点击左侧按钮生成情绪卡</div>
      <div class="ec-card" id="ec-card">
        <div class="ec-stamp">已生成 ✓</div>
        <div class="ec-yellow-bar">本集情绪卡</div>
        <div class="ec-body">
          <div class="ec-data-row"><span class="ec-dl">用户表达</span><span class="ec-dv" style="color:var(--red)">想留住</span></div>
          <div class="ec-data-row"><span class="ec-dl">情绪判断</span><span class="ec-dv" style="color:var(--blue)">留存表达型</span></div>
          <div class="ec-data-row"><span class="ec-dl">内容节点</span><span class="ec-dv">第12集 · 阳台烟火段落</span></div>
          <div class="ec-ai-box">
            <div class="ec-ai-label">AI 生成结果</div>
            <div class="ec-ai-quote">这一刻，好像真的值得被留下来。</div>
          </div>
          <div class="ec-brand">由 MOMERA 此刻 × 此刻在场 联合生成</div>
          <div class="ec-btns">
            <button class="btn" onclick="showToast('已保存 ✓')">保存情绪卡</button>
            <a href="#asset-library" class="btn btn-blue">进入资产库</a>
            <a href="#polaroid" class="btn btn-yellow">生成陪伴拍立得</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</section>

<!-- SECTION 03: ROUTE MATRIX -->
<section id="route-matrix">
<div class="inner">
  <p class="func-tag">FUNC 02</p>
  <h2 class="sec-title">广告版本路由矩阵</h2>
  <p class="sec-desc">同一个广告系统根据用户状态路由不同广告版本。</p>
  <div class="route-cards">
    <div class="route-card">
      <div class="rt-tag">ROUTE 1</div>
      <div class="rt-user">情绪沉浸型用户</div>
      <div class="rt-scene">内容场景：剧集 / 综艺 / IP</div>
      <ul class="rt-list">
        <li>情绪卡</li><li>角色卡</li><li>AI 具身陪伴单元</li>
      </ul>
    </div>
    <div class="route-card">
      <div class="rt-tag">ROUTE 2</div>
      <div class="rt-user">热血参与型用户</div>
      <div class="rt-scene">内容场景：体育 / 电竞</div>
      <ul class="rt-list">
        <li>阵营竞猜</li><li>赛况热度</li><li>观赛身份卡</li>
      </ul>
    </div>
    <div class="route-card">
      <div class="rt-tag">ROUTE 3</div>
      <div class="rt-user">场景效率型用户</div>
      <div class="rt-scene">内容场景：通勤 / 午休 / 睡前</div>
      <ul class="rt-list">
        <li>信息卡</li><li>AI 场景改造广告</li><li>轻量互动节点</li>
      </ul>
    </div>
  </div>
  <div class="route-bar">广告的关键不只是内容本身，而是以哪种版本进入用户此刻的体验。</div>
</div>
</section>

<!-- SECTION 04: SCENE REBUILD -->
<section id="scene-rebuild">
<div class="inner">
  <p class="func-tag">FUNC 03</p>
  <h2 class="sec-title">AI 场景改造展示</h2>
  <p class="scene-note">同一人物与产品主体不变，仅根据用户生活场景重构广告语境。</p>

  <div class="scene-trip" id="scene-trip">
    <img src="./assets/images/scene_rebuild_triptych.png" alt="场景改造三连图" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
    <div class="trip-fallback"><span>地铁通勤版</span><span>深夜工位版</span><span>天台晚风版</span></div>
  </div>

  <div class="scene-flow">
    <div class="scene-step">识别用户场景</div>
    <div class="scene-step">保留人物与产品主体</div>
    <div class="scene-step">重构背景、氛围与表达方式</div>
  </div>

  <div class="scene-video-preview">
    <div class="svp-title">改造对比预览</div>
    <div class="svp-grid">
      <div class="svp-left">
        <span class="svp-tag original">改造前 ORIGINAL</span>
        <div class="svp-video-wrap">
          <video src="./assets/videos/ad_drink_old.mp4" muted loop playsinline autoplay></video>
        </div>
      </div>
      <div class="svp-right">
        <span class="svp-tag rebuilt">场景改造后</span>
        <div class="svp-scenes">
          <div><div class="svp-sc"><video src="./assets/videos/ad_drink_scene_01.mp4" muted loop playsinline autoplay></video></div><div class="svp-sc-label">SCENE 01</div></div>
          <div><div class="svp-sc"><video src="./assets/videos/ad_drink_scene_02.mp4" muted loop playsinline autoplay></video></div><div class="svp-sc-label">SCENE 02</div></div>
          <div><div class="svp-sc"><video src="./assets/videos/ad_drink_scene_03.mp4" muted loop playsinline autoplay></video></div><div class="svp-sc-label">SCENE 03</div></div>
        </div>
      </div>
    </div>
  </div>
</div>
</section>

<!-- SECTION 05: ASSET LIBRARY -->
<section id="asset-library">
<div class="inner">
  <p class="func-tag">FUNC 04</p>
  <h2 class="sec-title">AI 数字资产库</h2>
  <p class="sec-desc">每一次互动，都沉淀为用户可保存、可展示、可分享的内容资产。</p>
  <div class="asset-wall">
    <!-- Card 1 -->
    <div class="asset-card">
      <div class="as-type">剧集资产</div>
      <div class="as-title">本集情绪卡</div>
      <span class="as-status gen">已生成</span>
      <span class="as-tag">留存表达型</span>
      <div class="as-preview">
        <svg viewBox="0 0 40 40"><path d="M20 8c-2 0-4 2-4 4v0c-4 0-8 2-8 6v12c0 2 2 3 4 3h16c2 0 4-1 4-3V18c0-4-4-6-8-6v0c0-2-2-4-4-4z" fill="none" stroke="#CCC" stroke-width="1.5"/><path d="M12 22c2 2 4 3 5 0 1-3 2 1 3 0 1-1 3-1 5 2" fill="none" stroke="#CCC" stroke-width="1.2"/></svg>
        <span class="as-ph-label">UI 预览</span>
      </div>
    </div>
    <!-- Card 2 - Featured -->
    <div class="asset-card">
      <div class="as-type">粉丝 / IP 资产</div>
      <div class="as-title">陪伴拍立得</div>
      <span class="as-status rare">稀有资产</span>
      <span class="as-tag">和TA同框一下</span>
      <div class="as-preview">
        <img src="./assets/images/polaroid_result_fireworks.png" alt="陪伴拍立得" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
        <div style="display:none;width:100%;height:100%;align-items:center;justify-content:center;font-size:24px;">✨ 陪伴拍立得</div>
      </div>
    </div>
    <!-- Card 3 -->
    <div class="asset-card">
      <div class="as-type">成长资产</div>
      <div class="as-title">追剧成就卡</div>
      <span class="as-status locked">待解锁</span>
      <span class="as-tag">连续追剧 7 天</span>
      <div class="as-preview">
        <svg viewBox="0 0 40 40"><path d="M20 6l3 10h10l-8 6 3 10-8-6-8 6 3-10-8-6h10z" fill="none" stroke="#CCC" stroke-width="1.5"/></svg>
        <span class="as-ph-label">UI 预览</span>
      </div>
    </div>
    <!-- Card 4 -->
    <div class="asset-card">
      <div class="as-type">身份资产</div>
      <div class="as-title">剧迷等级称号</div>
      <span class="as-status lit">已点亮</span>
      <span class="as-tag">高共鸣观众</span>
      <div class="as-preview">
        <svg viewBox="0 0 40 40"><circle cx="20" cy="20" r="14" fill="none" stroke="#CCC" stroke-width="1.5"/><path d="M13 22l5 5 9-9" fill="none" stroke="#CCC" stroke-width="1.5"/></svg>
        <span class="as-ph-label">UI 预览</span>
      </div>
    </div>
    <!-- Card 5 -->
    <div class="asset-card">
      <div class="as-type">体育资产</div>
      <div class="as-title">观赛身份卡</div>
