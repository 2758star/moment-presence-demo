      <div class="step-item" data-step="8"><span class="si-num">08</span>入库提示</div>
    </div>

    <!-- Center: Main content -->
    <div id="polaroid-main" style="min-width:0">

      <!-- STATE 1+2: Player + Quick replies -->
      <div class="step-panel show" data-panel="1">
        <div class="player-wrap sp-player">
          <div class="player-top">
            <div class="pt-left"><div class="pt-dot"></div><span class="pt-name">腾讯视频</span><span class="pt-sep">·</span><span class="pt-ep">假装偶然 · 第12集</span></div>
