<!-- SECTION 06: POLAROID FLOW -->
<section id="polaroid">
<div class="inner">
  <p class="func-tag">FUNC 05</p>
  <h2 class="sec-title">AI 具身陪伴拍立得 · 主流程</h2>

  <div class="pol-grid">
    <!-- Left: Step list -->
    <div class="step-list" id="step-list">
      <div class="step-item active" data-step="1"><span class="si-num">01</span>播放器缓冲节点</div>
      <div class="step-item" data-step="2"><span class="si-num">02</span>情绪引导</div>
